{
  "name": "goal-runner",
  "version": "0.1.1",
  "type": "module",
  "description": "Portable Codex-compatible /goal runtime with Pi and OpenCode adapters.",
  "keywords": [
    "pi-package",
    "opencode-plugin",
    "goal-runner",
    "codex-goal",
    "slash-command"
  ],
  "bin": {
    "goal-runner": "./dist/cli.js",
    "agent-goal": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./pi": "./dist/adapters/pi/index.js",
    "./pi/session-store": "./dist/adapters/pi/session-store.js",
    "./pi/workspace": "./dist/adapters/pi/workspace.js",
    "./opencode": "./dist/adapters/opencode/index.js",
    "./opencode/subagent-adapter": "./dist/adapters/opencode/subagent-adapter.js",
    "./opencode/workspace": "./dist/adapters/opencode/workspace.js",
    "./opencode/model-routing": "./dist/adapters/opencode/model-routing.js",
    "./opencode/monitor": "./dist/adapters/opencode/monitor-ui.js",
    "./opencode/closeout": "./dist/adapters/opencode/closeout.js",
    "./catalogs/bindings/pi.json": "./catalogs/bindings/pi.json",
    "./catalogs/bindings/opencode.json": "./catalogs/bindings/opencode.json"
  },
  "files": [
    "dist",
    "src",
    "templates",
    "schemas",
    "docs",
    "catalogs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist/tests/*.test.js",
    "check": "npm run build && npm test",
    "prepack": "npm run build",
    "smoke:opencode": "node -e \"import('./dist/adapters/opencode/index.js').then(m => console.log(typeof m.opencodeGoalPlugin, typeof m.OpencodeHarnessSubagentAdapter))\""
  },
  "pi": {
    "extensions": [
      "./dist/adapters/pi/index.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5345534/goal-runner.git"
  },
  "bugs": {
    "url": "https://github.com/a5345534/goal-runner/issues"
  },
  "homepage": "https://github.com/a5345534/goal-runner#readme",
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@opencode-ai/plugin": "*",
    "typebox": "*",
    "zod": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "@opencode-ai/plugin": {
      "optional": true
    },
    "typebox": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "goal-contract": "github:a5345534/goal-contract#bcb7668a2ee4128660dd80ca6a92828da8f56540"
  }
}
