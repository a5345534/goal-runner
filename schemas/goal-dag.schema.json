{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a5345534/goal-runner/schemas/goal-dag.schema.json",
  "title": "Agent Goal DAG",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "objective", "nodes"],
  "properties": {
    "version": { "const": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "defaults": { "$ref": "#/$defs/defaults" },
    "modelRouting": { "$ref": "#/$defs/modelRouting" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": { "$ref": "#/$defs/node" }
    }
  },
  "$defs": {
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "worktreeSlug": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$"
        },
        "branch": { "type": "string", "minLength": 1 },
        "baseRef": { "type": "string", "minLength": 1 }
      },
      "anyOf": [
        { "required": ["worktreeSlug"] },
        { "required": ["branch"] },
        { "required": ["baseRef"] }
      ]
    },
    "conflicts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "files": { "$ref": "#/$defs/stringList" },
        "modules": { "$ref": "#/$defs/stringList" },
        "capabilities": { "$ref": "#/$defs/stringList" }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "artifactLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "sourceNodeId": { "$ref": "#/$defs/kebabId" },
        "approvedByNodeId": { "$ref": "#/$defs/kebabId" },
        "approvedAt": { "type": "string", "minLength": 1 }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile": { "type": "string", "minLength": 1 },
        "testSpecNodeId": { "$ref": "#/$defs/kebabId" },
        "approvedByNodeId": { "$ref": "#/$defs/kebabId" },
        "artifactLocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactLock" }
        },
        "requiredEvidence": { "$ref": "#/$defs/stringList" },
        "onAuditTestGap": { "type": "string", "minLength": 1 },
        "diffBaseRef": { "type": "string", "minLength": 1 },
        "auditReportPaths": { "$ref": "#/$defs/stringList" },
        "allowedPaths": { "$ref": "#/$defs/stringList" },
        "forbiddenPaths": { "$ref": "#/$defs/stringList" }
      }
    },
    "scenarioId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[-_.][a-z0-9]+)*$"
    },
    "modelRouting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenarios"],
      "properties": {
        "scenarios": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "$ref": "#/$defs/scenarioId" },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["model"],
            "properties": {
              "model": { "type": "string", "minLength": 1, "description": "Canonical adapter-neutral model id in provider/model form; harness adapters translate it as needed." },
              "description": { "type": "string", "minLength": 1 }
            }
          }
        },
        "controllerScenario": { "$ref": "#/$defs/scenarioId" },
        "defaultSubagentScenario": { "$ref": "#/$defs/scenarioId" },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/modelRoutingRule" }
        }
      }
    },
    "modelRoutingRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario"],
      "properties": {
        "scenario": { "$ref": "#/$defs/scenarioId" },
        "when": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "nodeIds": { "$ref": "#/$defs/stringList" },
            "scopes": { "$ref": "#/$defs/stringList" },
            "risks": {
              "type": "array",
              "items": { "enum": ["low", "medium", "high"] }
            },
            "modules": { "$ref": "#/$defs/stringList" },
            "capabilities": { "$ref": "#/$defs/stringList" },
            "files": { "$ref": "#/$defs/stringList" },
            "objectiveIncludes": { "$ref": "#/$defs/stringList" },
            "hasValidators": { "type": "boolean" },
            "hasOutputs": { "type": "boolean" }
          }
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "outputs": { "$ref": "#/$defs/stringList" },
        "validators": { "$ref": "#/$defs/stringList" },
        "workspaceStrategy": { "type": "string", "minLength": 1 },
        "completionGates": { "$ref": "#/$defs/stringList" },
        "conflicts": { "$ref": "#/$defs/conflicts" },
        "modelScenario": { "$ref": "#/$defs/scenarioId" },
        "thinkingLevel": { "type": "string", "minLength": 1 }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "objective"],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "objective": { "type": "string", "minLength": 1 },
        "after": {
          "type": "array",
          "items": { "$ref": "#/$defs/kebabId" }
        },
        "outputs": { "$ref": "#/$defs/stringList" },
        "validators": { "$ref": "#/$defs/stringList" },
        "conflicts": { "$ref": "#/$defs/conflicts" },
        "scope": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "validation": { "$ref": "#/$defs/validation" },
        "workspaceStrategy": { "type": "string", "minLength": 1 },
        "workspace": { "$ref": "#/$defs/workspace" },
        "risk": { "enum": ["low", "medium", "high"] },
        "completionGates": { "$ref": "#/$defs/stringList" },
        "modelScenario": { "$ref": "#/$defs/scenarioId" },
        "thinkingLevel": { "type": "string", "minLength": 1 }
      }
    }
  }
}
