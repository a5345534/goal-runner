{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-goal-runtime/goal-ledger.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["sessionKey", "type", "at"],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "sessionKey": { "type": "string", "minLength": 1 },
    "goalId": { "type": "string", "minLength": 1 },
    "type": {
      "enum": [
        "goal_created",
        "goal_replaced",
        "goal_edited",
        "goal_paused",
        "goal_resumed",
        "goal_cleared",
        "turn_started",
        "turn_finished",
        "meaningful_progress",
        "no_progress_continuation_suppressed",
        "continuation_requested",
        "continuation_started",
        "continuation_already_started",
        "continuation_skipped",
        "continuation_retryable_failure",
        "continuation_fatal_failure",
        "completion_requested",
        "completion_audit_result",
        "goal_completed",
        "goal_blocked",
        "goal_budget_limited",
        "goal_usage_limited"
      ]
    },
    "at": { "type": "string", "format": "date-time" },
    "details": { "type": "object", "additionalProperties": true }
  }
}
